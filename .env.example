# SERVER-ONLY: never expose these values with NEXT_PUBLIC_.

# Preferred for judging/Azure integration.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-10-21

# Fallback for local development when Azure OpenAI is not configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: trust x-real-ip/x-forwarded-for only behind a trusted proxy.
TRUST_CLIENT_IP_HEADERS=false
